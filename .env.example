##############################
# PPI Curug Simulator Training
# .env template
##############################

# MongoDB Atlas / MongoDB connection string (required)
# Example:
# DATABASE_URL="mongodb+srv://<user>:<password>@<cluster-host>/<db>?retryWrites=true&w=majority"
DATABASE_URL="mongodb+srv://<user>:<password>@<cluster-host>/<db>?retryWrites=true&w=majority"

# JWT secret for session signing (required)
JWT_SECRET="replace-with-a-long-random-string"

# Optional: OTP secret for hashing OTP codes (defaults to JWT_SECRET)
OTP_SECRET=""

# Optional: where uploaded files are stored (default: uploads)
UPLOAD_DIR="uploads"

# Optional: base URL used to build links (reset password)
APP_URL="http://localhost:3000"

# Optional: base URL used for CTA links in HTML emails
APP_BASE_URL="http://localhost:3000"

# Optional: allowlist emails (comma-separated) that can bypass required document checks
DOCS_BYPASS_EMAILS=""

# Optional: protect the reminders cron endpoint in production
# Used by /api/public/cron/reminders/run
REMINDER_CRON_SECRET=""

# (Migration only) SQLite database URL (source). Keep dev.db if you're migrating from the old SQLite setup.
SQLITE_DATABASE_URL="file:./dev.db"

# SMTP (for OTP email verification and notifications)
# In development: if SMTP_* is not set, OTP will be logged to server console.
# Optional mail transport override: smtp | ethereal | log
MAIL_TRANSPORT="smtp"

# Gmail SMTP (disarankan pakai App Password)
# Catatan: Gmail umumnya menolak password login biasa untuk SMTP (error 535 BadCredentials).
# Solusi: aktifkan 2-Step Verification di Google Account lalu buat App Password untuk "Mail".
# - Port 465 = SSL (secure)
# - Port 587 = STARTTLS
# SMTP_FROM sebaiknya memakai alamat Gmail yang sama.
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=465
# SMTP_USER=yourname@gmail.com
# SMTP_PASS=xxxx xxxx xxxx xxxx  (App Password, 16 karakter; bisa tanpa spasi)
# SMTP_FROM="PPI Curug Simulator Training <yourname@gmail.com>"
SMTP_HOST=""
SMTP_PORT="587"
SMTP_USER=""
SMTP_PASS=""
SMTP_FROM="PPI Curug Simulator Training <no-reply@example.com>"

# Optional seed accounts (run: npm run db:seed)
SEED_ADMIN_EMAIL=""
SEED_ADMIN_PASSWORD=""
SEED_FINANCE_EMAIL=""
SEED_FINANCE_PASSWORD=""
SEED_INSTRUCTOR_EMAIL=""
SEED_INSTRUCTOR_PASSWORD=""
